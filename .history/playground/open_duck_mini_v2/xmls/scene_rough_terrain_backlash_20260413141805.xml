<mujoco model="Open Duck Mini V2 slope barrier scene">
  <include file="open_duck_mini_v2_backlash.xml"/>

  <statistic center="0 0 0.1" extent="0.8" meansize="0.04"/>

  <visual>
    <rgba force="1 0 0 1"/>
    <global azimuth="120" elevation="-20"/>
    <map force="0.01"/>
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0"
      width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance=".8"/>
    <material name="ramp" rgba="0.5 0.5 0.5 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <body name="floor">
      <geom name="floor" size="0 0 0.01" type="plane" material="groundplane" contype="1" conaffinity="0" priority="1"
        friction="1.0"/>
    </body>

    <!--
      Three-section slope barrier, centered at origin.
      Upslope 10cm + Platform 10cm + Downslope 10cm = 30cm total, 6mm max height.
      Width = 40cm. Thick boxes (10cm) extend below ground.
      angle = atan(0.006 / 0.1) ≈ 3.434°
    -->

    <!-- Upslope: x ∈ [-0.15, -0.05], z rises from 0 to 0.006 -->
    <body name="upslope">
      <geom name="upslope" type="box" size="0.05 0.2 0.05"
        pos="-0.1 0 -0.047" euler="0 -3.434 0"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>

    <!-- Platform: x ∈ [-0.05, 0.05], z = 0.006 -->
    <body name="platform">
      <geom name="platform" type="box" size="0.05 0.2 0.05"
        pos="0 0 -0.044"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>

    <!-- Downslope: x ∈ [0.05, 0.15], z descends from 0.006 to 0 -->
    <body name="downslope">
      <geom name="downslope" type="box" size="0.05 0.2 0.05"
        pos="0.1 0 -0.047" euler="0 3.434 0"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>
  </worldbody>

  <keyframe>
    <key name="home"
      qpos="
        0 0 0.15
        1 0 0 0

        0.002 0
        0.053 0
        -0.63 0
        1.368 0
        -0.784 0

        0
        0
        0
        0

        -0.003 0
        -0.065 0
        0.635 0
        1.379 0
        -0.796 0

      "
      ctrl="
          0.002
          0.053
          -0.63
          1.368
          -0.784

          0
          0
          0
          0
          
          -0.003
          -0.065
          0.635
          1.379
          -0.796
      "/>
  </keyframe>
</mujoco>