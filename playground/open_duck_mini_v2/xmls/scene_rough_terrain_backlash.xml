<mujoco model="Open Duck Mini V2 slope barrier scene">
  <include file="open_duck_mini_v2_backlash.xml"/>

  <statistic center="0 0 0.1" extent="0.8" meansize="0.04"/>

  <visual>
    <rgba force="1 0 0 1"/>
    <global azimuth="120" elevation="-20"/>
    <map force="0.01"/>
    <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0"
      width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance=".8"/>
    <material name="ramp" rgba="0.5 0.5 0.5 1"/>
    <!--
      Right-triangular-prism meshes (local coords):
        upslope : toe at local x=-0.1 z=0, vertical edge at local x=0 z=[0..0.006]
        downslope: vertical edge at local x=0 z=[0..0.006], toe at local x=+0.1 z=0
      Body pos shifts local x=0 to world x=-0.05 / +0.05 respectively.
    -->
    <mesh name="upslope_mesh"   file="upslope.stl"   scale="1 1 1"/>
    <mesh name="downslope_mesh" file="downslope.stl" scale="1 1 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <body name="floor">
      <geom name="floor" size="0 0 0.01" type="plane" material="groundplane" contype="1" conaffinity="0" priority="1"
        friction="1.0"/>
    </body>

    <!--
      Three-section slope barrier, centered at origin.
      Each ramp is a right-triangular prism: vertical edge 6mm, horizontal run 10cm.
      The vertical edge of each ramp is flush with the platform edge.
      Total length: 30 cm, max height: 6 mm, width: 40 cm.
    -->

    <!-- Upslope: x ∈ [-0.15, -0.05], vertical edge at x=-0.05 -->
    <body name="upslope" pos="-0.05 0 0">
      <geom name="upslope" type="mesh" mesh="upslope_mesh"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>

    <!-- Platform: x ∈ [-0.05, 0.05], top surface at z=0.006 -->
    <body name="platform">
      <geom name="platform" type="box" size="0.05 0.2 0.05"
        pos="0 0 -0.044"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>

    <!-- Downslope: x ∈ [0.05, 0.15], vertical edge at x=0.05 -->
    <body name="downslope" pos="0.05 0 0">
      <geom name="downslope" type="mesh" mesh="downslope_mesh"
        material="ramp" contype="1" conaffinity="0" priority="1" friction="1.0"/>
    </body>
  </worldbody>

  <keyframe>
    <key name="home"
      qpos="
        -0.3 0 0.15
        1 0 0 0

        0.002 0
        0.053 0
        -0.63 0
        1.368 0
        -0.784 0

        0
        0
        0
        0

        -0.003 0
        -0.065 0
        0.635 0
        1.379 0
        -0.796 0

      "
      ctrl="
          0.002
          0.053
          -0.63
          1.368
          -0.784

          0
          0
          0
          0
          
          -0.003
          -0.065
          0.635
          1.379
          -0.796
      "/>
  </keyframe>
</mujoco>